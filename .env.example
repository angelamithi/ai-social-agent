# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
#
# THIS FILE IS FOR LOCAL TESTING ONLY. On Render, you do not upload or
# use a .env file at all — instead, enter each of these same KEY=value
# pairs into Render's dashboard under each service's "Environment" tab
# (or once, into the shared "agent-secrets" Environment Group referenced
# in render.yaml, so both services pick them up without duplicating).
# Two exceptions that should NOT be set manually on Render:
#   - DATABASE_URL: Render auto-injects this once you link the agent-db
#     Postgres instance via render.yaml's `fromDatabase` — don't type
#     this in yourself there.
#   - WEBHOOK_PORT: Render sets $PORT itself; the start command already
#     uses --port $PORT, so this var is unused on Render entirely.

# Kill switch — set to "false" to instantly stop all autonomous posting
ENABLED=true

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (https://platform.openai.com) — used for image generation
# (GPT Image models). Note: GPT Image models may require completing
# "API Organization Verification" in your OpenAI developer console
# before they'll work, even with a valid key.
OPENAI_API_KEY=your_openai_api_key_here

# X (Twitter) API v2 — generate these in the X Developer Portal
# under your app's "Keys and tokens" tab. Your app needs
# "Read and write" permissions, and these must be USER ACCESS TOKENS
# (not just app-only bearer tokens) to post on your behalf.
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# WhatsApp Cloud API (Meta) — used for the manual approval step.
# See README for full setup (template creation/approval, webhook config).
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
# A random string you choose yourself — used only to verify the webhook
# handshake belongs to you. Make this up, e.g. a long random password.
WHATSAPP_VERIFY_TOKEN=choose_a_random_string_here
# This is the RECIPIENT number — your real personal WhatsApp number,
# the one you add as a "test recipient" in Meta's console and that
# receives the approval messages. It is NOT the sending number — the
# sending number is whatever WHATSAPP_PHONE_NUMBER_ID points to above
# (e.g. Meta's free test number while you're developing). E.164 format
# without the +, e.g. 254712345678
APPROVER_PHONE_NUMBER=your_whatsapp_number_here
# Name of the WhatsApp template you create and get approved (see README)
WHATSAPP_APPROVAL_TEMPLATE_NAME=post_approval_request
# Name of the named body variable in the template (e.g. {{post_summary}}).
# Meta's template builder now requires named placeholders, not {{1}}-style
# numbered ones — this must exactly match what you used when creating the
# template in WhatsApp Manager.
WHATSAPP_BODY_PARAM_NAME=post_summary
# Name of the SECOND WhatsApp template — for stage-1 (topic/draft
# selection) approval, showing 3 short previews with 3 quick-reply
# buttons ("Option 1"/"Option 2"/"Option 3"). Create and get this
# approved separately in WhatsApp Manager — see README.
WHATSAPP_OPTIONS_TEMPLATE_NAME=draft_options_request
# How many hours to wait for you to pick one of the 3 draft options
# before auto-selecting option 1. Only applies to the stage-1 (topic)
# selection — the final stage-2 post approval always waits indefinitely.
SELECTION_TIMEOUT_HOURS=8
# Public HTTPS URL this server is reachable at, so Meta can fetch the
# generated image for the template header. On Render this is your Web
# Service's onrender.com URL (or custom domain) — Render fills $PORT
# automatically, you don't need to set WEBHOOK_PORT there.
PUBLIC_BASE_URL=https://your-app-name.onrender.com
WEBHOOK_PORT=8443

# Shared Postgres connection string — both main.py (cron job) and
# webhook_server.py (web service) read/write the same database, since
# they run in separate containers with no shared filesystem on Render.
# On Render: create a Postgres instance, then add this to an
# Environment Group shared by both services (Render auto-fills the
# value if you link the database directly to each service instead).
# For local development against a Postgres without SSL configured,
# also set DATABASE_SSLMODE=disable below.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSLMODE=require

# Optional, not wired up yet — placeholder for future notification step
NOTIFY_EMAIL=
